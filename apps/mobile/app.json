{
  "expo": {
    "name": "Aegis",
    "slug": "aegis-security",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aegis.security",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Aegis scans your home network for security vulnerabilities."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030712"
      },
      "package": "com.aegis.security",
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_WIFI_STATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3b6bfa",
          "sounds": []
        }
      ]
    ],
    "scheme": "aegis",
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
