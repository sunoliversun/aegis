# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/aegis"

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth ───────────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_LITE="price_..."
STRIPE_PRICE_STANDARD="price_..."
STRIPE_PRICE_HOUSEHOLD="price_..."
STRIPE_PRICE_PREMIUM="price_..."

# ─── HaveIBeenPwned ─────────────────────────────────────────
HIBP_API_KEY="your-key"

# ─── SpyCloud (dark web breach intel) ───────────────────────
SPYCLOUD_API_KEY="your-key"

# ─── Experian Credit API ─────────────────────────────────────
EXPERIAN_CLIENT_ID="your-client-id"
EXPERIAN_CLIENT_SECRET="your-secret"
EXPERIAN_API_URL="https://us-api.experian.com"

# ─── Plaid (bank monitoring) ────────────────────────────────
PLAID_CLIENT_ID="your-client-id"
PLAID_SECRET="your-secret"
PLAID_ENV="sandbox"

# ─── Optery / EasyOptOuts (data broker removal) ─────────────
OPTERY_API_KEY="your-key"

# ─── Twilio (SMS alerts) ────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-token"
TWILIO_FROM_NUMBER="+1..."

# ─── SendGrid (email) ───────────────────────────────────────
SENDGRID_API_KEY="SG..."
SENDGRID_FROM_EMAIL="alerts@aegis.security"

# ─── Pusher (real-time websockets) ──────────────────────────
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="us2"
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# ─── PagerDuty (human analyst escalation) ───────────────────
PAGERDUTY_INTEGRATION_KEY="your-routing-key"
PAGERDUTY_API_KEY="your-api-key"

# ─── Shodan (network/IoT intelligence) ──────────────────────
SHODAN_API_KEY="your-key"

# ─── Encryption ─────────────────────────────────────────────
# 32-byte hex key for AES-256 encryption of PII
ENCRYPTION_KEY="your-32-byte-hex-key"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
